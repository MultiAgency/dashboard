# Environment Variables
# Copy this file to .env and fill in your values

# API Database (PostgreSQL)
# Docker dev:  postgres://everythingdev:everythingdev@localhost:5432/api_db
# Production:  postgres://user:pass@host:5432/dbname
# Fallback:    pglite:.bos/api/:memory:  (single-plugin only, crashes with multiple PGlite instances)
API_DATABASE_URL=postgres://everythingdev:everythingdev@localhost:5432/api_db

# Auth Database (PostgreSQL)
# Docker dev:  postgres://everythingdev:everythingdev@localhost:5433/auth_db
# Production:  postgres://user:pass@host:5432/dbname
# Fallback:    pglite:.bos/auth/:memory:  (single-plugin only, crashes with multiple PGlite instances)
AUTH_DATABASE_URL=postgres://everythingdev:everythingdev@localhost:5433/auth_db

# Projects Database (PostgreSQL)
# Docker dev:  postgres://everythingdev:everythingdev@localhost:5434/projects_db
# Production:  postgres://user:pass@host:5432/dbname
# Fallback:    pglite:.bos/projects/:memory:  (single-plugin only, crashes with multiple PGlite instances)
PROJECTS_DATABASE_URL=postgres://everythingdev:everythingdev@localhost:5434/projects_db

# Auth
BETTER_AUTH_SECRET=

# Zephyr Cloud (for deployment)
ZE_SERVER_TOKEN=
ZE_USER_EMAIL=

# NEAR (optional - for automated publishing)
# NEAR_PRIVATE_KEY=ed25519:...

# Registry relay (optional - for sponsored FastKV delegate submission)
# REGISTRY_RELAY_ACCOUNT_ID=dev.everything.near
# REGISTRY_RELAY_PRIVATE_KEY=ed25519:...
# REGISTRY_RELAY_NETWORK=mainnet

# FastKV registry namespace (optional - defaults to dev.everything.near)
# REGISTRY_FASTKV_MAINNET_NAMESPACE=dev.everything.near
# REGISTRY_FASTKV_TESTNET_NAMESPACE=dev.everything.near

# FastKV base URLs (optional - defaults to FastNear hosted endpoints)
# REGISTRY_FASTKV_MAINNET_URL=https://kv.main.fastnear.com
# REGISTRY_FASTKV_TESTNET_URL=https://kv.test.fastnear.com

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
