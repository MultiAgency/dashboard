# Environment Variables
# Copy this file to .env and fill in your values.
#
# For local dev, first start postgres containers:  docker compose up -d --wait
# Each plugin (api, auth, projects) gets its own postgres instance to avoid
# pglite's multi-instance WASM crash when 3+ plugins share one host process.

# API Database (postgres-api container on :5432)
API_DATABASE_URL=postgres://everythingdev:everythingdev@localhost:5432/api_db

# Auth Database (postgres-auth container on :5433)
AUTH_DATABASE_URL=postgres://everythingdev:everythingdev@localhost:5433/auth_db

# Projects Database (postgres-projects container on :5434)
PROJECTS_DATABASE_URL=postgres://everythingdev:everythingdev@localhost:5434/projects_db

# Better Auth secret (generate via `openssl rand -hex 32`)
BETTER_AUTH_SECRET=

# Agency DAO — this deployment's production Sputnik DAO contract.
# Without this, agency_settings.daoAccountId seeds to PLACEHOLDER.sputnik-dao.near
# and all admin routes lock until claimed via the bootstrap.config flow.
AGENCY_DAO_ACCOUNT=multiagency.sputnik-dao.near

# Zephyr Cloud (for deployment)
ZE_SERVER_TOKEN=
ZE_USER_EMAIL=

# NEAR (optional - for automated publishing)
# NEAR_PRIVATE_KEY=ed25519:...

# Required in production - URL of the host the API plugin runs behind.
# In dev the API falls back to http://localhost:${PORT:-3000}.
# HOST_URL=

# NEAR RPC (optional - defaults shown)
# NEAR_RPC_URL=https://rpc.mainnet.near.org

# CORS origins for auth (comma-separated)
# CORS_ORIGIN=http://localhost:3000

# GitHub OAuth (optional - leave blank to disable github provider)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Form-submission notifications (optional — each channel no-ops if unset).
# Fires on /apply + /register + /contact submissions; the row still persists to `applications` either way.
# Webhook: incoming-webhook URL (Discord/Slack/Zapier/etc.); the URL itself is the secret.
# APPLICATIONS_WEBHOOK_URL=
# Resend email: needs RESEND_API_KEY + NOTIFY_FROM_EMAIL (on a Resend-verified sending domain).
# The "to" is agency_settings.contactEmail.
# RESEND_API_KEY=
# NOTIFY_FROM_EMAIL=
