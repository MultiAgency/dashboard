# Environment Variables
# Copy this file to .env and fill in your values

# API Secrets
API_DATABASE_URL=postgres://multiagency:multiagency@localhost:5432/api_db
API_DATABASE_AUTH_TOKEN=

# Zephyr Cloud (for deployment)
ZE_SERVER_TOKEN=
ZE_USER_EMAIL=

# NEAR (optional - for automated publishing)
# NEAR_PRIVATE_KEY=ed25519:...

# Required in production - URL of the host the API plugin runs behind.
# In dev the API falls back to http://localhost:${PORT:-3000}.
# HOST_URL=

# Agency configuration (optional - defaults shown)
# AGENCY_DAO_ACCOUNT=multiagency.sputnik-dao.near
# NEAR_RPC_URL=https://rpc.mainnet.near.org
