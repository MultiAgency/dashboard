{
  "name": "api",
  "version": "2.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./contract": {
      "types": "./src/contract.ts",
      "default": "./src/contract.ts"
    }
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@libsql/client": "0.17.3",
    "@orpc/contract": "^1.13.4",
    "@orpc/server": "^1.13.4",
    "better-auth": "1.6.10",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.45.1"
  },
  "devDependencies": {
    "@effect/language-service": "^0.84.3",
    "@module-federation/node": "^2.7.40",
    "@rspack/cli": "^1.6.8",
    "@rspack/core": "^1.6.8",
    "@types/node": "^25.0.3",
    "dotenv": "^17.2.3",
    "everything-dev": "^1.9.1",
    "every-plugin": "^2.5.4",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.17",
    "zephyr-rspack-plugin": "^1.0.1"
  },
  "scripts": {
    "build": "bun run build:types && rspack build",
    "build:types": "tsc -p tsconfig.contract.json",
    "deploy": "bun run build:types && DEPLOY=true rspack build",
    "dev": "bun run build:types && bun --bun rspack serve",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  }
}
