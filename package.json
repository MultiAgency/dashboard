{
  "name": "monorepo",
  "private": true,
  "workspaces": {
    "packages": [
      "api",
      "ui"
    ],
    "catalog": {
      "react": "19.2.4",
      "react-dom": "19.2.4",
      "@tanstack/react-query": "5.90.20",
      "@tanstack/react-router": "1.157.16",
      "near-kit": "^0.12.0",
      "@hot-labs/near-connect": "^0.11.0",
      "drizzle-orm": "^0.45.1",
      "drizzle-kit": "^0.31.8",
      "better-auth": "1.6.9",
      "better-near-auth": "^0.5.2",
      "every-plugin": "^2.2.6",
      "typescript": "^5.9.3",
      "vitest": "^4.0.17",
      "@libsql/client": "0.17.0",
      "@types/node": "^25.0.3",
      "@types/react": "^19.2.7",
      "@types/react-dom": "^19.2.3",
      "effect": "3.21.0",
      "@module-federation/enhanced": "^2.3.2",
      "@module-federation/node": "^2.7.40",
      "@module-federation/rsbuild-plugin": "^2.3.2",
      "@module-federation/runtime-core": "^2.3.2",
      "@module-federation/sdk": "^2.3.2",
      "@module-federation/dts-plugin": "^2.3.2",
      "zod": "4.3.6",
      "@orpc/contract": "1.13.14"
    }
  },
  "scripts": {
    "dev": "bun node_modules/.bin/bos dev",
    "dev:ui": "bun node_modules/.bin/bos dev --api remote",
    "dev:api": "bun node_modules/.bin/bos dev --ui remote",
    "dev:proxy": "bun node_modules/.bin/bos dev --proxy",
    "build": "bun node_modules/.bin/bos build",
    "deploy": "bun node_modules/.bin/bos build --deploy",
    "publish": "bun node_modules/.bin/bos publish",
    "typecheck": "bun run --cwd ui tsc --noEmit && bun run --cwd api tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "start": "NODE_ENV=production bos start --port ${PORT:-3000} --env ${APP_ENV:-production} --no-interactive",
    "db:push": "bun run --cwd api drizzle-kit push",
    "db:studio": "bun run --cwd api drizzle-kit studio",
    "db:generate": "bun run --cwd api drizzle-kit generate",
    "db:migrate": "bun run --cwd api drizzle-kit migrate"
  },
  "packageManager": "bun@1.2.20",
  "type": "module",
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/bun": "latest",
    "dotenv": "^17.3.1",
    "tsx": "^4.21.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@orpc/contract": "^1.13.14",
    "every-plugin": "^2.2.6",
    "everything-dev": "^1.4.1"
  },
  "overrides": {
    "axios": "1.13.6",
    "effect": "3.21.0",
    "zod": "4.3.6",
    "@tanstack/router-generator>zod": "^3.24.2",
    "@orpc/contract": "1.13.14",
    "@orpc/server": "1.13.14"
  }
}
