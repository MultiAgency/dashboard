{
  "name": "monorepo",
  "private": true,
  "workspaces": {
    "packages": [
      "api",
      "ui"
    ],
    "catalog": {
      "react": "19.2.4",
      "react-dom": "19.2.4",
      "@tanstack/react-query": "5.90.20",
      "@tanstack/react-router": "1.157.16",
      "near-kit": "^0.14.0",
      "@hot-labs/near-connect": "^0.11.0",
      "drizzle-orm": "^0.45.1",
      "drizzle-kit": "^0.31.8",
      "better-auth": "1.6.9",
      "better-near-auth": "1.4.2",
      "every-plugin": "^2.5.8",
      "typescript": "^5.9.3",
      "vitest": "^4.0.17",
      "@types/node": "^25.0.3",
      "@types/react": "^19.2.7",
      "@types/react-dom": "^19.2.3",
      "effect": "3.21.0",
      "@module-federation/enhanced": "^2.3.2",
      "@module-federation/node": "^2.7.40",
      "@module-federation/rsbuild-plugin": "^2.3.2",
      "@module-federation/runtime-core": "^2.3.2",
      "@module-federation/sdk": "^2.3.2",
      "@module-federation/dts-plugin": "^2.3.2",
      "zod": "4.3.6",
      "@orpc/contract": "1.13.14",
      "@better-auth/api-key": "1.6.9",
      "@better-auth/passkey": "1.6.9",
      "everything-dev": "^1.12.4",
      "@scure/base": "^2.2.0",
      "pg": "^8.12.0",
      "@types/pg": "^8.11.6",
      "@electric-sql/pglite": "^0.4.5",
      "@orpc/server": "1.13.14",
      "@orpc/client": "1.13.14",
      "@orpc/zod": "1.13.14",
      "@orpc/openapi": "1.13.14",
      "@tanstack/intent": "^0.0.40",
      "@opentelemetry/api": "^1.9.0"
    }
  },
  "scripts": {
    "dev": "bun node_modules/.bin/bos dev",
    "dev:ui": "bun node_modules/.bin/bos dev --api remote",
    "dev:api": "bun node_modules/.bin/bos dev --ui remote",
    "dev:proxy": "bun node_modules/.bin/bos dev --proxy",
    "build": "bun node_modules/.bin/bos build",
    "deploy": "bun node_modules/.bin/bos build --deploy",
    "publish": "bun node_modules/.bin/bos publish",
    "typecheck": "bun run --cwd ui tsc --noEmit & bun run --cwd api tsc --noEmit & wait",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "start": "NODE_ENV=production bos start --port ${PORT:-3000} --env ${APP_ENV:-production} --no-interactive ${BOS_ACCOUNT:+--account $BOS_ACCOUNT}",
    "db:push": "bun run --cwd api drizzle-kit push",
    "db:studio": "bun run --cwd api drizzle-kit studio",
    "db:generate": "bun run --cwd api drizzle-kit generate",
    "db:migrate": "bun run --cwd api drizzle-kit migrate",
    "types:gen": "node_modules/.bin/bos types gen",
    "postinstall": "node_modules/.bin/bos types gen || true",
    "init": "bun run db:migrate",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "echo 'Packages versioned - skipping npm publish'",
    "test": "bun run test:api && bun run test:e2e",
    "test:api": "cd api && bun run test tests/integration/ tests/unit/",
    "test:integration": "cd api && bun run test tests/integration/",
    "test:e2e": "bun run --cwd host test:e2e",
    "dev:postgres": "docker compose up -d --wait && bun run dev",
    "dev:postgres:down": "docker compose down",
    "dev:postgres:reset": "docker compose down -v && docker compose up -d --wait"
  },
  "packageManager": "bun@1.2.20",
  "type": "module",
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/bun": "latest",
    "dotenv": "^17.3.1",
    "tsx": "^4.21.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.6",
    "@changesets/cli": "^2.29.8"
  },
  "dependencies": {
    "@electric-sql/pglite": "catalog:",
    "@orpc/contract": "^1.13.14",
    "better-near-auth": "catalog:",
    "every-plugin": "catalog:",
    "everything-dev": "catalog:",
    "@better-auth/api-key": "catalog:",
    "@better-auth/passkey": "catalog:",
    "@hot-labs/near-connect": "0.11.2",
    "@orpc/server": "^1.13.14",
    "better-auth": "catalog:",
    "drizzle-orm": "^0.45.1",
    "effect": "catalog:",
    "zod": "catalog:",
    "@opentelemetry/api": "catalog:"
  },
  "overrides": {
    "axios": "1.13.6",
    "effect": "3.21.0",
    "@orpc/contract": "1.13.14",
    "@orpc/server": "1.13.14",
    "@hot-labs/near-connect": "0.11.2"
  },
  "module": "index.ts",
  "peerDependencies": {
    "typescript": "^5"
  }
}
