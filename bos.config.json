{
  "extends": "bos://dev.everything.near/everything.dev",
  "account": "multiagentic.near",
  "domain": "multiagency.ai",
  "title": "MultiAgency",
  "description": "Human-led, AI-native agencies for hire.",
  "testnet": "agency.testnet",
  "staging": {
    "domain": "dev.multiagency.ai"
  },
  "repository": "https://github.com/MultiAgency/dashboard",
  "app": {
    "ui": {
      "name": "ui",
      "development": "local:ui"
    },
    "api": {
      "name": "api",
      "development": "local:api",
      "secrets": [
        "API_DATABASE_URL",
        "APPLICATIONS_WEBHOOK_URL",
        "RESEND_API_KEY",
        "NOTIFY_FROM_EMAIL"
      ]
    }
  },
  "plugins": {
    "projects": {
      "development": "https://elliot-braem-3560-everything-dev-projects-plugin--0039ec9c5-ze.zephyrcloud.app",
      "secrets": [
        "PROJECTS_DATABASE_URL"
      ],
      "routes": [
        "ui/src/routes/_layout/_authenticated/organizations/**",
        "ui/src/routes/_layout/_authenticated/projects/**"
      ],
      "sidebar": [
        {
          "icon": "FolderKanban",
          "label": "projects"
        }
      ]
    }
  },
  "shared": {
    "ui": {
      "effect": {
        "version": "3.21.0",
        "requiredVersion": "^3.21.0",
        "singleton": true,
        "strictVersion": false,
        "shareScope": "default"
      },
      "zod": {
        "version": "4.3.6",
        "requiredVersion": "^4.3.6",
        "singleton": true,
        "strictVersion": false,
        "shareScope": "default"
      },
      "@orpc/contract": {
        "version": "1.13.14",
        "requiredVersion": "^1.13.14",
        "singleton": true,
        "strictVersion": false,
        "shareScope": "default"
      },
      "better-auth": {
        "version": "1.6.10",
        "requiredVersion": "^1.6.10",
        "singleton": true,
        "strictVersion": false,
        "shareScope": "default"
      },
      "better-near-auth": {
        "version": "1.4.2",
        "requiredVersion": "^1.4.2",
        "singleton": true,
        "strictVersion": false,
        "shareScope": "default"
      },
      "@better-auth/api-key": {
        "version": "1.6.10",
        "requiredVersion": "^1.6.10",
        "singleton": true,
        "strictVersion": false,
        "shareScope": "default"
      },
      "@better-auth/passkey": {
        "version": "1.6.10",
        "requiredVersion": "^1.6.10",
        "singleton": true,
        "strictVersion": false,
        "shareScope": "default"
      }
    },
    "plugins": {}
  }
}
