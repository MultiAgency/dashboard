{
  "extends": "bos://auth.everything.near/everything.dev",
  "account": "agency.near",
  "domain": "multiagency.ai",
  "testnet": "agency.testnet",
  "staging": {
    "domain": "dev.multiagency.ai"
  },
  "repository": "https://github.com/MultiAgency/dashboard",
  "app": {
    "ui": {
      "name": "ui",
      "development": "local:ui"
    },
    "api": {
      "name": "api",
      "development": "local:api",
      "secrets": ["API_DATABASE_URL"]
    },
    "auth": {
      "name": "everything-dev_auth-plugin",
      "secrets": ["AUTH_DATABASE_URL", "BETTER_AUTH_SECRET", "CORS_ORIGIN"]
    }
  },
  "plugins": {},
  "shared": {
    "ui": {
      "effect": {
        "version": "3.21.0",
        "requiredVersion": "^3.21.0",
        "singleton": true,
        "strictVersion": false,
        "shareScope": "default"
      },
      "zod": {
        "version": "4.3.6",
        "requiredVersion": "^4.3.6",
        "singleton": true,
        "strictVersion": false,
        "shareScope": "default"
      }
    }
  }
}
