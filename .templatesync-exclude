# Files copied on `bos init` but never overwritten on `bos sync`.
# These are agency-owned — every fork customizes them after init.

# Brand identity — every agency writes its own
ui/public/**

# Agent guides — agency's own conventions and decisions
AGENTS.md
README.md
CONTRIBUTING.md

# UI routes — agency-specific pages and layouts
ui/src/routes/**

# API contract and entry point — agency defines its own API surface
api/src/contract.ts
api/src/index.ts

# Database driver, dev plugin, and migration config
api/src/db/index.ts
api/plugin.dev.ts
api/drizzle.config.ts

# Database schema — agency defines its own data model
api/src/db/schema.ts

# Migration history — agency's own data history; never overwrite
api/src/db/migrations/**

# Service integrations — agency customizes Sputnik / NEARN / token registry
api/src/services/**

# Agency-specific admin UI components
ui/src/components/admin-*.tsx

# Token registry and formatting helpers
ui/src/lib/format-amount.ts

# Generated files — always regenerated by `bos types gen`
ui/src/api-contract.gen.ts
api/src/plugins-client.gen.ts
ui/src/routeTree.gen.ts
