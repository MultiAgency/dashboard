{
  "name": "ui",
  "version": "1.1.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "rsbuild dev",
    "dev:ssr": "PORT=3003 BUILD_TARGET=server rsbuild dev",
    "build": "bun run build:client && bun run build:ssr",
    "deploy": "DEPLOY=true bun run build",
    "build:client": "BUILD_TARGET=client rsbuild build",
    "build:ssr": "BUILD_TARGET=server rsbuild build",
    "preview": "rsbuild preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build:types": "tsc --declaration --emitDeclarationOnly --outDir dist/types"
  },
  "dependencies": {
    "@better-auth/api-key": "^1.6.10",
    "@better-auth/passkey": "^1.6.10",
